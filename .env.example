# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.
#
# These variables are only needed when running the orchestrator
# in on-chain mode (--chain flag). Mock mode needs none of them.

# RPC endpoint for the chain the contracts are deployed on.
# Use http://localhost:8545 for a local Hardhat node.
DAI_RPC_URL=http://localhost:8545

# Deployed contract addresses (printed by scripts/deploy.js after deployment)
DAI_SLASHING_CONTRACT=0x...
DAI_PAYMENT_CONTRACT=0x...
DAI_TOKEN_CONTRACT=0x...
DAI_DISTRIBUTOR_CONTRACT=0x...

# Optional: seconds between reward-settlement epochs (default 3600)
# DAI_SETTLE_INTERVAL=3600

# Orchestrator wallet private key.
# Must hold UPDATER_ROLE on MerkleDistributor + ORCHESTRATOR_ROLE on
# SlashingContract (granted automatically by deploy.js). It is NOT a token
# minter — rewards settle via the distributor, not a hot mint key.
# On a local Hardhat node the first test account works fine.
# NEVER use a wallet with real funds on mainnet for this role.
DAI_ORCHESTRATOR_KEY=0x...

# Miner wallet (set this on the machine running compute/node.py)
DAI_WALLET=0x...
