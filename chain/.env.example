# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# RPC endpoints (get free ones from Alchemy or Infura)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY

# Deployer wallet private key (testnet only — never use a wallet with real funds)
DEPLOYER_PRIVATE_KEY=0xabc123...

# Block explorer API keys (for contract verification — optional)
ETHERSCAN_API_KEY=
POLYGONSCAN_API_KEY=
